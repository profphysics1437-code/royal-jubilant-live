// Royal Jubilant Real Estate LLC — full enterprise schema
// Public website + admin portal data model.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ---- Identity & RBAC ---------------------------------------------------

model User {
  id            String   @id @default(cuid())
  email         String   @unique
  name          String?
  phone         String?
  role          String   @default("customer") // customer | agent | admin
  passwordHash  String?
  avatarUrl     String?
  preferredLang String?
  googleId      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  leads         Lead[]
  appointments  Appointment[]
  savedProperties SavedProperty[]
  savedSearches SavedSearch[]
  messages      Message[]
  notifications Notification[]
  properties    Property[]      @relation("PropertyAgent")
  blogs         BlogPost[]
  crmNotes      CrmNote[]
  commissions   Commission[]
}

// ---- Properties (admin-managed) ----------------------------------------

model Property {
  id               String   @id @default(cuid())
  reference        String   @unique
  title            String
  slug             String   @unique
  // Section 1 — Listing Type & Purpose
  status           String   // sale | rent
  category         String?  // Residential | Commercial
  type             String   // Apartment | Villa | Townhouse | Penthouse | Studio | Duplex | Compound | Office | Retail | Warehouse | Labor Camp | Shop | Factory
  // Section 2 — Location
  country          String?  // UAE | Saudi Arabia | Qatar | ...
  emirate          String?  // Dubai | Abu Dhabi | ...
  community        String
  subCommunity     String?
  locationLat      Float?
  locationLng      Float?
  locationAddress  String?
  // Section 3 — Property Details
  bedrooms         Int      @default(0)
  bathrooms        Int      @default(0)
  area             Float
  areaUnit         String?  @default("sqft") // sqft | sqm
  plotSize         Float?
  plotSizeUnit     String?  @default("sqft")
  completionStatus String?  // Ready | Off-Plan
  completionDate   String?  // e.g. "2027-Q1" — stored as string to allow flexible month/year
  furnishingStatus String?  // Furnished | Unfurnished | Partially Furnished
  floorNumber      Int?
  totalFloors      Int?
  parking          Int      @default(0)
  // Section 4 — Pricing & Payment
  price            Float
  pricePerSqft     Float?
  rentFrequency    String?  // Yearly | Monthly | Weekly | Daily
  noOfCheques      Int?
  serviceCharge    Float?
  priceNegotiable  Boolean  @default(false)
  // Section 5 — Amenities & Features (all stored as JSON arrays)
  indoorFeatures   String?  // JSON array
  outdoorFeatures  String?  // JSON array
  buildingAmenities String? // JSON array
  nearbyLandmarks  String?  // JSON array
  viewFeatures     String?  // JSON array (renamed from "view" to avoid SQL reserved word)
  // Section 6 — Media
  images           String   // JSON array as string
  floorPlanUrl     String?
  videoUrl         String?
  virtualTourUrl   String?
  // Section 7 — Description & Reference
  description      String
  reraNumber       String?  // Mandatory for UAE
  exclusiveListing Boolean  @default(false)
  // Section 8 — Agent details (auto-filled from agent's User/Agent profile)
  developer        String?  // kept for backwards compatibility
  furnished        Boolean  @default(false) // kept for backwards compat (derived from furnishingStatus)
  amenities        String   // JSON array — kept for backwards compat (legacy combined amenities)
  features         String   // JSON array — kept for backwards compat
  paymentPlan      String?  // JSON array — kept for backwards compat
  handoverYear     Int?     // kept for backwards compat
  // Flags
  featured         Boolean  @default(false)
  isLatest         Boolean  @default(true)
  isLuxury         Boolean  @default(false)
  published        Boolean  @default(true)
  views            Int      @default(0)

  agentId          String?
  agent            User?    @relation("PropertyAgent", fields: [agentId], references: [id], onDelete: SetNull)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  savedBy          SavedProperty[]
  leads            Lead[]
}

model SavedProperty {
  id          String   @id @default(cuid())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  propertyId  String?
  externalRef String?
  createdAt   DateTime @default(now())

  @@unique([userId, externalRef])
}

model SavedSearch {
  id        String   @id @default(cuid())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  name      String
  filters   String
  createdAt DateTime @default(now())
}

// ---- CRM / Leads -------------------------------------------------------

model Lead {
  id          String   @id @default(cuid())
  name        String
  email       String
  phone       String?
  whatsapp    String?
  source      String
  intent      String?
  message     String?
  budget      Float?
  propertyRef String?
  community   String?

  status      String   @default("new")
  assignedTo  String?
  notes       String?

  user        User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId      String?

  property    Property? @relation(fields: [propertyId], references: [id], onDelete: SetNull)
  propertyId  String?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  appointments Appointment[]
  crmNotes    CrmNote[]
}

model Appointment {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String?
  agentEmail String?
  propertyRef String?
  scheduledAt DateTime
  type      String
  status    String   @default("scheduled")
  notes     String?
  createdAt DateTime @default(now())
}

model Message {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  userId    String?
  fromEmail String
  toEmail   String
  subject   String?
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(cuid())
  user      User?    @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String?
  title     String
  body      String
  type      String   @default("info")
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// Agent CRM notes (per-lead, per-agent)
model CrmNote {
  id        String   @id @default(cuid())
  agent     User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId   String
  lead      Lead?    @relation(fields: [leadId], references: [id], onDelete: Cascade)
  leadId    String?
  note      String
  createdAt DateTime @default(now())
}

// Commission tracking per closed deal
model Commission {
  id            String   @id @default(cuid())
  agent         User     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentId       String
  propertyRef   String?
  leadId        String?
  dealValue     Float
  commissionPct Float    @default(2.0)
  commissionAmt Float
  status        String   @default("pending") // pending | invoiced | paid
  paidAt        DateTime?
  createdAt     DateTime @default(now())
}

// ---- Newsletter & Valuations ------------------------------------------

model NewsletterSubscriber {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  locale    String?  @default("en")
  createdAt DateTime @default(now())
}

model ValuationRequest {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String?
  whatsapp     String?
  propertyType String?
  community    String?
  bedrooms     Int?
  bathrooms    Int?
  area         Float?
  condition    String?
  ownership    String?
  timeline     String?
  message      String?
  status       String   @default("new")
  createdAt    DateTime @default(now())
}

model MortgageEnquiry {
  id           String   @id @default(cuid())
  name         String
  email        String
  phone        String?
  propertyPrice Float
  downPayment  Float
  loanTenor    Int?
  employment   String?
  salary       Float?
  residency    String?
  status       String   @default("new")
  createdAt    DateTime @default(now())
}

// ---- Admin-managed content --------------------------------------------

model Agent {
  id                String   @id @default(cuid())
  name              String
  title             String
  photo             String
  phone             String
  whatsapp          String
  email             String   @unique
  languages         String   // JSON array
  specializations   String   // JSON array
  communities       String   // JSON array
  biography         String
  awards            String   // JSON array
  rating            Float    @default(5.0)
  reviewsCount      Int      @default(0)
  activeListings    Int      @default(0)
  soldProperties    Int      @default(0)
  experienceYears   Int      @default(0)
  linkedin          String?
  instagram         String?
  twitter           String?
  order             Int      @default(0)
  published         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Community {
  id              String   @id @default(cuid())
  name            String
  shortName       String
  hero            String
  overview        String
  lifestyle       String
  averagePrice    String
  pricePerSqft    String
  roi             String
  population      String
  totalProperties Int
  rating          Float    @default(4.5)
  highlights      String   // JSON array
  schools         String   // JSON array
  hospitals       String   // JSON array
  transport       String   // JSON array
  shopping        String   // JSON array
  nearbyCommunities String // JSON array
  stats           String   // JSON array
  published       Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model Developer {
  id                String   @id @default(cuid())
  name              String
  logo              String
  founded           String
  headquarters      String
  overview          String
  totalProjects     Int
  completedProjects Int
  ongoingProjects   Int
  awards            String   // JSON array
  hero              String
  topProjects       String   // JSON array
  published         Boolean  @default(true)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model BlogPost {
  id        String   @id @default(cuid())
  title     String
  excerpt   String
  category  String
  date      DateTime @default(now())
  readTime  String
  authorName String
  image     String
  content   String?
  published Boolean  @default(true)
  authorId  String?
  author    User?    @relation(fields: [authorId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  location  String
  avatar    String
  rating    Int      @default(5)
  quote     String
  service   String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

model Award {
  id        String   @id @default(cuid())
  title     String
  issuer    String
  year      String
  icon      String   @default("award")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
}

// ---- Site Settings (admin-editable text) -------------------------------

model SiteSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  category  String   @default("general")
  updatedAt DateTime @updatedAt
}

// ---- Audit & Settings -------------------------------------------------

model AuditLog {
  id        String   @id @default(cuid())
  actor     String
  action    String
  entity    String?
  entityId  String?
  meta      String?
  createdAt DateTime @default(now())
}

// ---- Phase 1: CMS Models ---------------------------------------------------

model HeroSlide {
  id        String   @id @default(cuid())
  order     Int      @default(0)
  heading1  String
  heading2  String
  heading3  String?
  subtitle  String
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Location {
  id        String   @id @default(cuid())
  name      String
  emirate   String   @default("Dubai")
  country   String   @default("UAE")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PropertyCategory {
  id        String   @id @default(cuid())
  name      String
  type      String   @default("residential")
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Amenity {
  id        String   @id @default(cuid())
  name      String
  category  String   @default("indoor")
  icon      String?
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String?
  userName  String
  userRole  String
  action    String
  entity    String
  entityId  String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

// ---- Phase 2: CMS Models ---------------------------------------------------

model MediaFile {
  id        String   @id @default(cuid())
  filename  String
  url       String
  type      String   // image | video | pdf | icon | svg
  folder    String   @default("general")
  size      Int      @default(0)
  altTag    String?
  caption   String?
  uploadedBy String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Popup {
  id          String   @id @default(cuid())
  title       String
  content     String
  type        String   @default("info")
  trigger     String   @default("immediate")
  delaySeconds Int     @default(0)
  position    String   @default("center")
  imageUrl    String?
  buttonText  String?
  buttonLink  String?
  startDate   DateTime?
  endDate     DateTime?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SeoMeta {
  id              String   @id @default(cuid())
  pageSlug        String   @unique
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  ogTitle         String?
  ogDescription   String?
  ogImage         String?
  twitterCard     String?  @default("summary_large_image")
  keywords        String?
  structuredData  String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model MenuItem {
  id        String   @id @default(cuid())
  label     String
  url       String   @default("")
  view      String?  // internal store action, e.g. "rent", "buy", "about-offplan"
  desc      String?  // short description shown in dropdown
  badge     String?  // optional badge text e.g. "New", "CMS"
  parentId  String?  // for sub-menus; null = top-level
  order     Int      @default(0)
  icon      String?  // lucide-react icon name e.g. "Building", "Home"
  menu      String   @default("main")  // which menu group: main, footer, mobile
  visible   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([menu, visible])
  @@index([parentId])
}

// ---- Phase 3: Advanced Enterprise Models ----------------------------------

model EmailTemplate {
  id          String   @id @default(cuid())
  name        String   @unique
  slug        String   @unique
  subject     String
  body        String
  category    String   @default("transactional")
  variables   String?
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model LandingPage {
  id          String   @id @default(cuid())
  title       String
  slug        String   @unique
  headline    String
  subheadline String?
  body        String
  heroImage   String?
  ctaText     String?
  ctaLink     String?
  seoTitle    String?
  seoDescription String?
  status      String   @default("draft")
  publishedAt DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ReportSnapshot {
  id          String   @id @default(cuid())
  type        String
  period      String
  summary     String
  generatedBy String?
  createdAt   DateTime @default(now())
}

// ---- FAQ & Video Models ----------------------------------------------------

model Faq {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String   @default("general")
  order     Int      @default(0)
  published Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Video {
  id          String   @id @default(cuid())
  title       String
  advisor     String
  role        String   @default("Property Consultant")
  category    String   @default("Market Insights")
  duration    String   @default("0:00")
  thumbnail   String
  description String
  videoUrl    String?
  youtubeUrl  String?
  order       Int      @default(0)
  published   Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
