{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/agent/layout,_N_T_/agent/notes/layout,_N_T_/agent/notes/page,_N_T_/agent/notes"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/agent/notes/__PAGE__",
    "/agent/notes",
    "/agent",
    "/_index",
    "/_head"
  ]
}