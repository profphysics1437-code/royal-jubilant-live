{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/popups/layout,_N_T_/admin/popups/page,_N_T_/admin/popups"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/admin/popups/__PAGE__",
    "/admin/popups",
    "/admin",
    "/_index",
    "/_head"
  ]
}