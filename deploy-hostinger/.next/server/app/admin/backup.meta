{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/admin/layout,_N_T_/admin/backup/layout,_N_T_/admin/backup/page,_N_T_/admin/backup"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/admin/backup/__PAGE__",
    "/admin/backup",
    "/admin",
    "/_index",
    "/_head"
  ]
}